# Copy this file to `.env.docker` before running Docker Compose.

# Keep your existing hosted Postgres unless you explicitly want to containerize that too.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_POOL_MAX=5

# Public app URL for NextAuth and Google OAuth callbacks.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
SLACK_CLIENT_ID=replace-me
SLACK_CLIENT_SECRET=replace-me
SLACK_REDIRECT_URI=http://localhost:3000/api/slack/callback
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_BOT_USERNAME=replace-me
TELEGRAM_WEBHOOK_SECRET=replace-with-a-long-random-secret
TELEGRAM_NOTIFICATION_INTERVAL_MS=2000

OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_EMBEDDING_BATCH_SIZE=64
OPENAI_EMBEDDING_BATCH_MAX_CHARS=200000
OPENAI_CHAT_CONCURRENCY=10
OPENAI_EMBEDDING_CONCURRENCY=3
OPENAI_CLASSIFICATION_MIN_INTERVAL_MS=0
SEMANTIC_MATCH_THRESHOLD=0.5
DAILY_SEMANTIC_INITIAL_LOOKBACK_HOURS=36
DAILY_SEMANTIC_LOOKBACK_HOURS=36

OPENAI_WEB_SEARCH_MODEL=gpt-5-mini
OPENAI_SUBREDDIT_MODEL=gpt-5-mini
OPENAI_SUBREDDIT_WEB_SEARCH_CONTEXT_SIZE=high
OPENAI_SUBREDDIT_VALIDATION_TIMEOUT_MS=8000

REDDIT_RSS_USER_AGENT=reddit-leads-local/1.0
REDDIT_RSS_REQUEST_INTERVAL_MS=30000
REDDIT_RSS_REQUEST_JITTER_MS=30000
REDDIT_RSS_MAX_RETRIES=1
REDDIT_RSS_RETRY_BACKOFF_MS=60000

WORKER_INGESTION_CONCURRENCY=1
WORKER_EMBEDDING_CONCURRENCY=3
WORKER_SEMANTIC_CONCURRENCY=3
WORKER_CLASSIFICATION_CONCURRENCY=10
WORKER_NOTIFICATIONS_CONCURRENCY=1

# Compose overrides this to use the local Redis container.
REDIS_URL=redis://redis:6379
