# Copy to `.env.rss-poll-worker` on the RSS poll worker VM and replace placeholders.
#
# This VM does not run Redis. Point REDIS_URL at the existing Redis used by the
# current worker fleet so queued embedding and semantic jobs are consumed there.

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
REDIS_URL=redis://:PASSWORD@EXISTING_REDIS_HOST:6379

REDDIT_RSS_USER_AGENT=reddit-leads-rss-poll-worker/1.0
REDDIT_RSS_REQUEST_INTERVAL_MS=30000
REDDIT_RSS_REQUEST_JITTER_MS=30000
REDDIT_RSS_MAX_RETRIES=1
REDDIT_RSS_RETRY_BACKOFF_MS=60000

RSS_POLL_REFILL_LOW_WATERMARK=10
RSS_POLL_REFILL_HIGH_WATERMARK=100
RSS_POLL_REFILL_INTERVAL_MS=30000
RSS_POLL_REFILL_LOCK_TTL_MS=60000
