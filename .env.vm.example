# Copy to `.env.vm` on the Lightsail VM and replace all placeholder values.

# Self-hosted PostgreSQL. Use URL-safe alphanumeric passwords so the generated
# connection URLs do not require additional percent-encoding.
POSTGRES_DB=reddit_leads
POSTGRES_OWNER_USER=reddit_leads_owner
POSTGRES_OWNER_PASSWORD=replace-with-a-long-url-safe-owner-password
POSTGRES_APP_USER=reddit_leads_app
POSTGRES_APP_PASSWORD=replace-with-a-long-url-safe-app-password

# Compose builds the private DATABASE_URL for VM containers from the values
# above. Vercel uses the public PgBouncer URL from the deployment guide.
DATABASE_POOL_MAX=5

# Worker-side Redis password
REDIS_PASSWORD=replace-with-a-strong-random-password

# Worker runtime
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_EMBEDDING_BATCH_SIZE=64
OPENAI_EMBEDDING_BATCH_MAX_CHARS=200000
OPENAI_CHAT_CONCURRENCY=10
OPENAI_EMBEDDING_CONCURRENCY=3
OPENAI_CLASSIFICATION_MIN_INTERVAL_MS=0
SEMANTIC_MATCH_THRESHOLD=0.5
OPENAI_WEB_SEARCH_MODEL=gpt-5-mini
OPENAI_SUBREDDIT_MODEL=gpt-5-mini
OPENAI_SUBREDDIT_WEB_SEARCH_CONTEXT_SIZE=high
OPENAI_SUBREDDIT_VALIDATION_TIMEOUT_MS=8000
REDDIT_RSS_USER_AGENT=reddit-leads-worker/1.0
REDDIT_RSS_REQUEST_INTERVAL_MS=30000
REDDIT_RSS_REQUEST_JITTER_MS=30000
REDDIT_RSS_MAX_RETRIES=1
REDDIT_RSS_RETRY_BACKOFF_MS=60000
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_NOTIFICATION_INTERVAL_MS=2000

# Conservative defaults for a 2 CPU / 4 GB Lightsail VM shared with PostgreSQL.
WORKER_INGESTION_CONCURRENCY=1
WORKER_EMBEDDING_CONCURRENCY=2
WORKER_SEMANTIC_CONCURRENCY=2
WORKER_CLASSIFICATION_CONCURRENCY=4
WORKER_NOTIFICATIONS_CONCURRENCY=1

# DB maintenance worker. It preserves all leads and deletes only old non-lead
# Reddit items plus old diagnostics/logs.
DB_MAINTENANCE_INTERVAL_MS=14400000
DB_MAINTENANCE_REDDIT_ITEM_RETENTION_HOURS=48
DB_MAINTENANCE_RAW_JSON_RETENTION_HOURS=24
DB_MAINTENANCE_RSS_EVENT_RETENTION_HOURS=48
DB_MAINTENANCE_INITIAL_RSS_EVENT_RETENTION_DAYS=7
DB_MAINTENANCE_RUN_RETENTION_DAYS=14
DB_MAINTENANCE_AI_USAGE_RETENTION_DAYS=30
DB_MAINTENANCE_BATCH_SIZE=1000
DB_MAINTENANCE_MAX_RUNTIME_MS=45000
DB_MAINTENANCE_VACUUM_ENABLED=true
